%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: d83216bd693669442a8dccc246e8fc22, type: 3}
  m_Name: ProfilingFeedbackRepository
  m_EditorClassIdentifier: 
  SingleContainer: {fileID: 781630661673262138, guid: 45c500a3433090b41bfe6ad005d270cf, type: 3}
  MultipleContainer: {fileID: 781630661673262138, guid: 4689bb12224f63240ac0e3056d230e01, type: 3}
  chapters:
  - ChapterName: Introduzione
    feedbacks:
    - FeedbackName: Introduzione 1
      pages:
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 1
        image: {fileID: 0}
        video: {fileID: 0}
        text: "Questa che stai leggendo \xE8 una delle tante diapositive che ti guider\xE0
          per tutta l'applicazione.\n\nLe diapositive contengono informazioni utili
          su come agire in un determinato momento. \n\nSe ti allontani da una diapositiva,
          questa verr\xE0 ridotta ad icona. Puoi seguire le icone per capire dove
          devi andare. Per muoverti nello spazio, utilizza la levette dei controller.\n\nProva
          ad allontanarti dalla diapositiva."
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 1
        image: {fileID: 756281117, guid: ff61970423d43d84bbffcfd785997454, type: 3}
        video: {fileID: 0}
        text: "Questa che stai leggendo \xE8 una delle tante diapositive che ti guider\xE0
          per tutta l'applicazione.\n\nLe diapositive contengono informazioni utili
          su come agire in un determinato momento. \n\nSe ti allontani da una diapositiva,
          questa verr\xE0 ridotta ad icona. Puoi seguire le icone per capire dove
          devi andare. Per muoverti nello spazio, utilizza la levette dei controller.\n\nProva
          ad allontanarti dalla diapositiva."
      StepForCompletition:
      - Guarda il primo feedback
      PersonalizedPrefab: {fileID: 0}
    - FeedbackName: Introduzione 2
      pages:
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 1
        image: {fileID: 21300000, guid: b181d6dfee62edb4eb03ecc9626d572d, type: 3}
        video: {fileID: 0}
        text: "Per interagire con elementi 2D, come bottoni e pannelli, utilizza
          il pulsante mostrato in figura puntando verso il punto desiderato; in alternativa,
          puoi portare fisicamente il controller sopra l\u2019elemento senza premere
          alcun pulsante.\n\nPer provare, scorri la barra presente sulla sinistra,
          ti permetter\xE0 di leggere tutto il testo.\n\nBravo!"
      StepForCompletition:
      - clicca sulal barra scorrevole
      PersonalizedPrefab: {fileID: 0}
    - FeedbackName: Introduzione 3
      pages:
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 1
        image: {fileID: 0}
        video: {fileID: 0}
        text: "Ottimo lavoro, stai imparando in fretta. \n\nQuesta che vedi \xE8
          una diapositiva pi\xF9 complessa. Contiene diverse slide che potrai navigare
          nell'ordine che preferisci.\n\nClicca sul bottone corrispondente alla pagina
          2, sulla sinistra.\n\n"
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: "Fantastico! Non \xE8 da tutti cliccare cos\xEC bene un bottone. Sei
          davvero portato!"
      StepForCompletition:
      - Clicca sulla seconda pagina
      PersonalizedPrefab: {fileID: 0}
    - FeedbackName: Introduzione 4
      pages:
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 1
        image: {fileID: 0}
        video: {fileID: 0}
        text: "Tra le pagine presenti, quella che si chiama \"Overview\" ti da informazioni
          generiche sui task da svolgere, ed \xE8 solitamente l'ultima pagina.\n\nPuoi
          navigare tra le pagine nell'ordine che vuoi, quindi assicurati di guardare
          prima quella se vuoi avere subito un quadro generale.\n\nClicca sulla slide
          \"Overview\"."
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: "Sei fuori strada fratello, questa non \xE8 la slide \"Overview\""
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: "Stai sbagliando bello, questa \xE8 una slide per persone sequenziali,
          che sono chiuse mentalmente e monotone e hanno bisogno di avere tutto il
          futuro programmato nei minimi dettagli"
      - Sequenzale_Globale: 1
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: Porca vacca ma cosa ti danno da mangiare?! Sei un fenomeno!
      StepForCompletition:
      - Clicca su slide globale
      PersonalizedPrefab: {fileID: 0}
    - FeedbackName: Introduzione 5
      pages:
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 1
        image: {fileID: 21300000, guid: ce79b042749569346b9094d0c91b26b2, type: 3}
        video: {fileID: 0}
        text: 'Bene, Per interagire invece con gli oggetti che troverai durante il
          tuo percorso puoi usare il tasto laterale mostrato nell''immagine.


          Afferra
          uno degli oggetti che vedi attorno a te, puntando il controller o avvicinandolo
          all''oggetto desiderato.


          Ricorda: gli oggetti con cui dovrai
          interagire lampeggeranno al momento giusto!'
      StepForCompletition:
      - Grab Oggetti
      PersonalizedPrefab: {fileID: 0}
    - FeedbackName: Introduzione 6
      pages:
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 1
        image: {fileID: 0}
        video: {fileID: 0}
        text: "Ok figliolo, \xE8 il momento di aprire le ali. C'\xE8 tutto un mondo
          di minigiochi ancora da esplorare. \n\nVoltati e apri la porta premendo
          il bottone. Per premere oggetti come i bottoni, avvicina il controller
          al bottone come faresti con la mano. Adios!"
      StepForCompletition:
      - Premi il bottone per aprire la porta
      PersonalizedPrefab: {fileID: 0}
  - ChapterName: Cassaforte
    feedbacks:
    - FeedbackName: Apri la cassaforte
      pages:
      - Sequenzale_Globale: 1
        Visivo_Verbale: 1
        isIntroductory: 1
        image: {fileID: 0}
        video: {fileID: 0}
        text: "Ehi, tu! Vuoi fare dei VERI soldi finti? Sto parlando di un mucchio
          di sonanti quattrini digitali. \n\nDentro questa cassaforte troverai quello
          che fa al caso tuo."
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: "<color=#888787><size=85%><b>Step da completare</b></size></color>\r\n\r\n<b><size=90%>1.</size></b>
          Cerca gli indizi sopra il meccanismo a cilindri.  \r\nPotrebbero rivelarti
          la sequenza corretta.\r\n\r\n<b><size=90%>2.</size></b> Osserva con attenzione
          il sistema di manopole e cilindri numerati.  \r\nRuota le manopole per
          far scorrere i numeri sui cilindri.\r\n\r\n<b><size=90%>3.</size></b> Analizza
          bene ci\xF2 che vedi e individua i <b>quattro numeri</b> della password.\r\n\r\n<b><size=90%>4.</size></b>
          Quando pensi di aver trovato la sequenza corretta,  \r\ninseriscila nella
          tastiera numerica della cassaforte.\r\n\r\n<b><size=90%>5.</size></b> Se
          la sequenza \xE8 giusta, si accender\xE0 una luce verde.\r\n\r\n<b><size=90%>6.</size></b>
          Se invece compare una luce rossa,  \r\nla password \xE8 errata... ma puoi
          riprovare tutte le volte che vuoi."
      - Sequenzale_Globale: 1
        Visivo_Verbale: 0
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 32900000, guid: c6e163ad5fec7d348b2e9f5c72209cd5, type: 3}
        text: 
      - Sequenzale_Globale: 1
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: "<color=#888787><size=85%><b>Scopo</b></size></color>\r\n<size=90%>Individuare
          la combinazione numerica corretta per aprire la cassaforte e ottenere la
          ricompensa.</size>\r\n\r\n<color=#888787><size=85%><b>Mosse</b></size></color>\r\n<size=90%>\u2022
          Ruotare le manopole per osservare i numeri sui cilindri\r\n\u2022 Leggere
          gli indizi per dedurre la combinazione\r\n\u2022 Inserire la sequenza tramite
          tastiera numerica</size>\r\n\r\n<color=#888787><size=85%><b>Attenzione</b></size></color>\r\n<size=90%>\u2022
          Puoi riprovare quante volte vuoi senza penalit\xE0</size>"
      StepForCompletition:
      - Interagisci con le manopole
      - Inserisci la password
      - Apri la porta
      - Goditi il bottino
      PersonalizedPrefab: {fileID: 0}
  - ChapterName: Bloxorz
    feedbacks:
    - FeedbackName: Istruzioni Bloxorz
      pages:
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 1
        image: {fileID: 0}
        video: {fileID: 0}
        text: "Bloxorz \xE8 un puzzle game in cui controlli un blocco rettangolare
          da far rotolare su piattaforme sospese, con l\u2019obiettivo di farlo cadere
          esattamente in un foro."
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: "<color=#888787><size=85%><b>Step da completare</b></size></color>\r\n\r\n<b><size=90%>1.</size></b>
          Usa i pulsanti per far rotolare la pedina nelle quattro direzioni:  \r\nsu,
          gi\xF9, sinistra e destra.\r\n\r\n<b><size=90%>2.</size></b> Fai attenzione
          ai bordi del campo:  \r\nse la pedina sporge, cadr\xE0 e dovrai ricominciare
          da capo.\r\n\r\n<b><size=90%>3.</size></b> Utilizza le caselle colorate
          per aprire i ponti  \r\nche collegano le diverse piattaforme.\r\n\r\n<b><size=90%>4.</size></b>
          Casella blu: si attiva semplicemente passando sopra con la pedina.\r\n\r\n<b><size=90%>5.</size></b>
          Casella rossa: si attiva solo se la pedina \xE8 posizionata  \r\nverticalmente
          sopra di essa, senza toccare le caselle circostanti.\r\n\r\n<b><size=90%>6.</size></b>
          Per vincere, fai cadere la pedina verticalmente nel foro  \r\ncentrando
          perfettamente il buco."
      - Sequenzale_Globale: 1
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: "<color=#888787><size=85%><b>Scopo</b></size></color>\n<size=90%>Guidare
          la pedina attraverso la piattaforma, attraversare i ponti e cadere nel
          foro corretto.</size>\n\n<color=#888787><size=85%><b>Mosse</b></size></color>\n<size=90%>\u2022
          Premere i pulsanti direzionali per muovere la pedina\n- Centrare le caselle
          colorate per aprire i ponti\n- Far cadere la pedina nel foro target</size>\n\n<color=#888787><size=85%><b>Attenzione</b></size></color>\n<size=90%>\u2022
          Cadere dai bordi della piattaforma reimposta il livello</size>"
      - Sequenzale_Globale: 1
        Visivo_Verbale: 0
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 32900000, guid: 1c3e48304cc73684994997bbdaf94dc0, type: 3}
        text: <i><size=60%>Puoi usare i tasti per far ripartire il video, fermarlo
          o andare avanti e indietro.</size></i>
      StepForCompletition:
      - Prima mossa (bloxorz)
      - Gioca a bloxorz
      PersonalizedPrefab: {fileID: 0}
  - ChapterName: Sokoban
    feedbacks:
    - FeedbackName: Istruzione Sokoban
      pages:
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 1
        image: {fileID: 0}
        video: {fileID: 0}
        text: "Sokoban \xE8 un classico rompicapo in cui il giocatore deve spingere
          delle casse all\u2019interno di un magazzino fino a posizionarle sui punti
          designati.\nIl gioco richiede pianificazione strategica, poich\xE9 ogni
          mossa \xE8 irreversibile e uno spostamento sbagliato pu\xF2 rendere il
          livello impossibile da completare."
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: "<color=#888787><size=85%><b>Step da completare</b></size></color>\r\n\r\n<b><size=90%>1.</size></b>
          Seleziona una pedina puntandola con il controller  \r\ne muovila con il
          joystick davanti a te.\r\n\r\n<b><size=90%>2.</size></b> Puoi muovere la
          pedina su due assi:  \r\nin alto o in basso, a destra o sinistra.\r\n\r\n<b><size=90%>3.</size></b>
          Se la pedina tocca una parete del campo,  \r\nil movimento sull\u2019asse
          corrispondente verr\xE0 bloccato.\r\n\r\n<b><size=90%>4.</size></b> Se
          la pedina passa sopra un buco, ci cadr\xE0 dentro  \r\ne non potrai pi\xF9
          muoverla.\r\n\r\n<b><size=90%>5.</size></b> Usa le pedine rosse per riempire
          i buchi.\r\n\r\n<b><size=90%>6.</size></b> Se sbagli mossa, puoi tornare
          indietro di un solo passo  \r\ncon il pulsante \u201CBack\u201D.\r\n\r\n<b><size=90%>7.</size></b>
          Se necessario, premi il pulsante \u201CReset\u201D  \r\nper ricominciare
          da capo."
      - Sequenzale_Globale: 1
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: "<color=#888787><size=85%><b>Scopo</b></size></color>\n<size=90%>Portare
          ogni pedina numerata sulla casella corretta; usare le rosse per coprire
          i buchi.</size>\n\n<color=#888787><size=85%><b>Mosse</b></size></color>\n<size=90%>\u2022
          Selezionare una pedina con il joystick\n- Spostarla sulla casella corretta\n-
          Usare le pedine rosse per coprire i buchi</size>\n\n<color=#888787><size=85%><b>Attenzione</b></size></color>\n<size=90%>\u2022
          Le pedine non si muovono se bloccate da pareti o altre pedine\n- Se incastrato
          puoi tornare indietro di una mossa o resettare la partita</size>"
      StepForCompletition:
      - Prima mossa (sokoban)
      - Gioca a sokoban
      PersonalizedPrefab: {fileID: 0}
  - ChapterName: Scalak
    feedbacks:
    - FeedbackName: Istruzioni Scalak
      pages:
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 1
        image: {fileID: 0}
        video: {fileID: 0}
        text: "Scalak \xE8 un puzzle game in cui l\u2019obiettivo \xE8 completare
          forme geometriche combinando e incastrando pezzi di vario tipo."
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: "<color=#888787><size=85%><b>Step da completare</b></size></color>\r\n\r\n<b><size=90%>1.</size></b>
          Osserva la disposizione delle tessere nel campo  \r\ne individua le possibili
          combinazioni di movimento in base alle loro posizioni.\r\n\r\n<b><size=90%>2.</size></b>
          Seleziona una tessera tramite raycast o toccandola con il controller. 
          \r\nI volumi visualizzati indicano le posizioni disponibili.\r\n\r\n<b><size=90%>3.</size></b>
          Scegli uno dei volumi evidenziati per spostare la tessera  \r\nnella posizione
          corrispondente.\r\n\r\n<b><size=90%>4.</size></b> Continua a riordinare
          le tessere fino a ricostruire una disposizione coerente.\r\n\r\n<b><size=90%>5.</size></b>
          Una volta completato il riordino, posiziona le forme sulla destra  \r\nall\u2019interno
          dei fori corrispondenti.\r\n\r\n<b><size=90%>6.</size></b> L\u2019ordine
          corretto \xE8 quello che riproduce la sequenza di forme mostrata sulla
          destra."
      - Sequenzale_Globale: 1
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: "<color=#888787><size=85%><b>Scopo</b></size></color>\n<size=90%>Riordinare
          le tessere secondo il pattern mostrato, poi posizionare le forme sui fori.</size>\n\n<color=#888787><size=85%><b>Mosse</b></size></color>\n<size=90%>\u2022
          Osservare l'ordine delle forme mostrato a destra\n- Selezionare una tessera
          e spostarla nelle caselle illuminate\n- Posizionare le forme sui fori corrispondenti</size>\n\n<color=#888787><size=85%><b>Attenzione</b></size></color>\n<size=90%>\u2022
          Le forme vanno posizionate sui fori solo dopo aver riordinato le tessere</size>"
      - Sequenzale_Globale: 1
        Visivo_Verbale: 0
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 32900000, guid: b6ef6359817d3914a9a9e61bef26b2f0, type: 3}
        text: <i><size=60%>Puoi usare i tasti per far ripartire il video, fermarlo
          o andare avanti e indietro.</size></i>
      StepForCompletition:
      - Prima mossa (scalak)
      - Gioca a scalak
      PersonalizedPrefab: {fileID: 0}
  - ChapterName: Visivo-Verbale
    feedbacks:
    - FeedbackName: Ricorda la sequenza
      pages:
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 1
        image: {fileID: 0}
        video: {fileID: 0}
        text: In questo gioco di memoria dovrai interagire con gli oggetti nell'ordine
          mostrato.
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: "<color=#888787><size=85%><b>Step da completare</b></size></color>\r\n\r\n<b><size=90%>1.</size></b>
          Prima di iniziare, esplora gli oggetti e prova le interazioni  \r\nper
          familiarizzare con il loro comportamento.\r\n\r\n<b><size=90%>2.</size></b>
          Premi il pulsante per far comparire una sequenza sullo schermo.\r\n\r\n<b><size=90%>3.</size></b>
          Memorizza attentamente la sequenza, che pu\xF2 essere composta  \r\nda
          immagini oppure da parole.\r\n\r\n<b><size=90%>4.</size></b> Replicala
          interagendo con gli oggetti nell\u2019ordine corretto.\r\n\r\n<b><size=90%>5.</size></b>
          Se non ricordi la sequenza, torna allo schermo e premi nuovamente il pulsante 
          \r\nper visualizzarla di nuovo.\r\n\r\n<b><size=90%>6.</size></b> Se interagisci
          con un oggetto nel momento sbagliato, questo lampegger\xE0 di rosso  \r\nindicando
          l\u2019errore.\r\n\r\n<b><size=90%>7.</size></b> Dopo ogni round, premi
          nuovamente il pulsante per cambiare modalit\xE0  \r\ne completare sia la
          sequenza di parole che quella di immagini."
      - Sequenzale_Globale: 1
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: "<color=#888787><size=85%><b>Scopo</b></size></color>\n<size=90%>Memorizzare
          la sequenza mostrata e replicarla interagendo con gli oggetti.</size>\n\n<color=#888787><size=85%><b>Mosse</b></size></color>\n<size=90%>\n-
          Interagire con gli oggetti prima di iniziare per familiarizzare con il
          loro funzionamento\n- Premere il pulsante per vedere la sequenza sullo
          schermo\n- Interagire con gli oggetti nell'ordine memorizzato\n- Ripremere
          il pulsante una volta finito un round per passare alla prossima modalit\xE0</size>\n\n<color=#888787><size=85%><b>Attenzione</b></size></color>\n<size=90%>\n-
          Puoi tornare allo schermo in qualsiasi momento per rivedere la sequenza\n-
          Entrambe le modalit\xE0 devono essere completate per concludere il gioco</size>"
      StepForCompletition:
      - inizia a giocare a ricordaInteractable
      - Ricorda gli interactable
      PersonalizedPrefab: {fileID: 0}
    - FeedbackName: Memory
      pages:
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 1
        image: {fileID: 0}
        video: {fileID: 0}
        text: "L'obbiettivo del gioco \xE8 girare le coppie di carte uguali, dopo
          averle memorizzate"
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: "<color=#888787><size=85%><b>Step da completare</b></size></color>\r\n\r\n<b><size=90%>1.</size></b>
          Premi il pulsante per iniziare il round.  \r\nLe carte verranno scoperte
          per alcuni secondi.\r\n\r\n<b><size=90%>2.</size></b> Memorizza la posizione
          delle coppie prima che le carte tornino coperte.\r\n\r\n<b><size=90%>3.</size></b>
          Seleziona le carte puntandole con il controller.\r\n\r\n<b><size=90%>4.</size></b>
          Trova le coppie corrette: se selezioni due carte uguali,  \r\nrimarranno
          scoperte fino alla fine del gioco.\r\n\r\n<b><size=90%>5.</size></b> Una
          volta completato il round, premi nuovamente il pulsante  \r\nper passare
          all\u2019altra modalit\xE0."
      - Sequenzale_Globale: 1
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: "<color=#888787><size=85%><b>Scopo</b></size></color>\n<size=90%>Abbinare
