  MultipleContainer: {fileID: 781630661673262138, guid: 4689bb12224f63240ac0e3056d230e01, type: 3}
  chapters:
  - ChapterName: Cassaforte
    feedbacks:
    - FeedbackName: Apri la cassaforte
      pages:
      - Sequenzale_Globale: 1
        Visivo_Verbale: 1
        isIntroductory: 1
        image: {fileID: 0}
        video: {fileID: 0}
        text: "L\u2019unico problema \xE8 che le casseforti hanno il difetto di essere
          chiuse a chiave quando non sono tue.\n\nMa ehi, non tutto \xE8 perduto!
          il propietario potrebbe aver scritto la password da qualche parte. \n\nSu
          un foglietto magari. Oppure costrunedo un complicato meccanismo di manopole
          e cilindri numerati. "
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: 'Ruota le manopole per far scorrere i numeri sui cilidri.


          Osserva
          bene e trova i quattro numeri della password.'
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: "Quando pensi di aver trovato la giusta sequenza, digitala sulla tastiera
          numerica della cassaforte.\n\nSe ci hai visto giusto si accender\xE0 una
          luce verde.\n\nSe la luce \xE8 rossa hai sbagliato password,  ma potrai
          riprovare quante volte vorrai."
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: "Una volta inserita la giusta sequenza, afferra la maniglia con il
          controller e apri la porta.\n\nGoditi i tuoi dollaroni, sei ufficialmente
          la persona pi\xF9 ricca di questo mondo virtuale!"
      - Sequenzale_Globale: 1
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: "Ehi, tu! Vuoi fare dei VERI soldi finti? Sto parlando di un mucchio
          di sonanti quattrini digitali. \n\nDentro questa cassaforte troverai quello
          che fa al caso tuo."
      StepForCompletition:
      - Interagisci con le manopole
      - Inserisci la password
      - Apri la porta
      - Goditi il bottino
      PersonalizedPrefab: {fileID: 0}
