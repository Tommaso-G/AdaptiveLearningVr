%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: d83216bd693669442a8dccc246e8fc22, type: 3}
  m_Name: ProfilingFeedbackRepository
  m_EditorClassIdentifier: 
  SingleContainer: {fileID: 781630661673262138, guid: 45c500a3433090b41bfe6ad005d270cf, type: 3}
  MultipleContainer: {fileID: 781630661673262138, guid: 4689bb12224f63240ac0e3056d230e01, type: 3}
  chapters:
  - ChapterName: Introduzione
    feedbacks:
    - FeedbackName: Introduzione 1
      pages:
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 1
        image: {fileID: 0}
        video: {fileID: 0}
        text: "Questa che stai leggendo \xE8 una delle tante diapositive che ti guider\xE0
          per tutta l'applicazione.\n\nLe diapositive contengono informazioni utili
          su come agire in un determinato momento. \n\nSe ti allontani da una diapositiva,
          questa verr\xE0 ridotta ad icona. Puoi seguire le icone per capire dove
          devi andare. \n\nUna volta completato uno step, vedrai comparire un \"check\"
          sull'icona o sulla diapositiva. \n\nProva ad allontanarti dalla diapositiva."
      StepForCompletition:
      - Guarda il primo feedback
      PersonalizedPrefab: {fileID: 0}
    - FeedbackName: Introduzione 2
      pages:
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 1
        image: {fileID: 0}
        video: {fileID: 0}
        text: "Ottimo lavoro, stai imparando in fretta. \n\nQuesta che vedi \xE8
          una diapositiva pi\xF9 complessa. Contiene diverse slide che potrai navigare
          nell'ordine che preferisci.\n\nClicca sul bottone corrispondente alla pagina
          2, sulla sinistra"
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: "Fantastico! Non \xE8 da tutti cliccare cos\xEC bene un bottone. Sei
          davvero portato!"
      StepForCompletition:
      - Clicca sulla seconda pagina
      PersonalizedPrefab: {fileID: 0}
    - FeedbackName: Introduzione 3
      pages:
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 1
        image: {fileID: 0}
        video: {fileID: 0}
        text: "Tra le pagine presenti, quella che si chiama \"Overview\" ti da informazioni
          generiche sui task da svolgere, ed \xE8 solitamente l'ultima pagina.\n\nPuoi
          navigare tra le pagine nell'ordine che vuoi, quindi assicurati di guardare
          prima quella se vuoi avere subito un quadro generale.\n\nClicca sulla slide
          \"Overview\"."
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: "Sei fuori strada fratello, questa non \xE8 la slide \"Overview\""
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: "Stai sbagliando bello, questa \xE8 una slide per persone sequenziali,
          che sono chiuse mentalmente e monotone e hanno bisogno di avere tutto il
          futuro programmato nei minimi dettagli"
      - Sequenzale_Globale: 1
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: Porca vacca ma cosa ti danno da mangiare?! Sei un fenomeno!
      StepForCompletition:
      - Clicca su slide globale
      PersonalizedPrefab: {fileID: 0}
    - FeedbackName: Introduzione 4
      pages:
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 1
        image: {fileID: 0}
        video: {fileID: 0}
        text: "Ok figliolo, \xE8 il momento di aprire le ali. C'\xE8 tutto un mondo
          di minigiochi ancora da esplorare. \n\nVoltati e segui le icone."
      StepForCompletition:
      - dirigiti fuori
      PersonalizedPrefab: {fileID: 0}
  - ChapterName: Cassaforte
    feedbacks:
    - FeedbackName: Apri la cassaforte
      pages:
      - Sequenzale_Globale: 1
        Visivo_Verbale: 1
        isIntroductory: 1
        image: {fileID: 0}
        video: {fileID: 0}
        text: "Ehi, tu! Vuoi fare dei VERI soldi finti? Sto parlando di un mucchio
          di sonanti quattrini digitali. \n\nDentro questa cassaforte troverai quello
          che fa al caso tuo."
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: "L\u2019unico problema \xE8 che le casseforti hanno il difetto di essere
          chiuse a chiave quando non sono tue.\n\nMa ehi, non tutto \xE8 perduto!
          il propietario potrebbe aver scritto la password da qualche parte. \n\nSu
          un foglietto magari. Oppure costrunedo un complicato meccanismo di manopole
          e cilindri numerati. "
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: 'Ruota le manopole per far scorrere i numeri sui cilidri.


          Osserva
          bene e trova i quattro numeri della password.'
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: "Quando pensi di aver trovato la giusta sequenza, digitala sulla tastiera
          numerica della cassaforte.\n\nSe ci hai visto giusto si accender\xE0 una
          luce verde.\n\nSe la luce \xE8 rossa hai sbagliato password,  ma potrai
          riprovare quante volte vorrai."
      - Sequenzale_Globale: 1
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: "<color=#888787><size=85%><b>Scopo</b></size></color>\n<size=90%>Individuare
          la combinazione numerica corretta per aprire la cassaforte e ottenere la
          ricompensa.</size>\n\n<color=#888787><size=85%><b>Mosse</b></size></color>\n<size=90%>\u2022
          Ruotare le manopole per osservare i numeri sui cilindri\n- Leggere gli
          indizi per dedurre la combinazione\n- Inserire la sequenza tramite tastiera
          numerica</size>\n\n<color=#888787><size=85%><b>Attenzione</b></size></color>\n<size=90%>\u2022
          Puoi riprovare quante volte vuoi senza penalit\xE0</size>"
      StepForCompletition:
      - Interagisci con le manopole
      - Inserisci la password
      - Apri la porta
      - Goditi il bottino
      PersonalizedPrefab: {fileID: 0}
  - ChapterName: Bloxorz
    feedbacks:
    - FeedbackName: Istruzione Bloxorz
      pages:
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 1
        image: {fileID: 0}
        video: {fileID: 0}
        text: "L\u2019obiettivo del gioco \xE8 far entrare la pedina nel buco in
          fondo al campo."
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: "Usa i pulsanti per far rotolare la pedina nelle 4 direzioni: su, gi\xF9,
          sinistra e destra."
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: "Se fai sporgere la pedina dai bordi del campo, questa cadr\xE0 e dovrai
          ricominciare da capo."
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: "Usa le caselle colorare per aprire i ponti che collegano le piattaforme.\n\nCasella
          blu: per attivare l\u2019effetto basta passarci sopra con la pedina\n\nCasella
          rossa: per attivare l\u2019effetto la pedina deve trovarsi sopra la casella
          verticalmente, senza toccare quelle circostanti."
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: 'Per centrare il buco e vincere il gioco, la pedina deve cadere verticalmente
          nel foro. '
      - Sequenzale_Globale: 1
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: "<color=#888787><size=85%><b>Scopo</b></size></color>\n<size=90%>Guidare
          la pedina attraverso la piattaforma, attraversare i ponti e cadere nel
          foro corretto.</size>\n\n<color=#888787><size=85%><b>Mosse</b></size></color>\n<size=90%>\u2022
          Premere i pulsanti direzionali per muovere la pedina\n- Centrare le caselle
          colorate per aprire i ponti\n- Far cadere la pedina nel foro target</size>\n\n<color=#888787><size=85%><b>Attenzione</b></size></color>\n<size=90%>\u2022
          Cadere dai bordi della piattaforma reimposta il livello</size>"
      StepForCompletition:
      - Prima mossa (bloxorz)
      - Gioca a bloxorz
      PersonalizedPrefab: {fileID: 0}
  - ChapterName: Sokoban
    feedbacks:
    - FeedbackName: Istruzione Sokoban
      pages:
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 1
        image: {fileID: 0}
        video: {fileID: 0}
        text: "L\u2019obiettivo del gioco \xE8 portare le pedine numerate sulle caselle
          corrette."
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: Seleziona una pedina con il raycast e muovila con il joystick davanti
          a te.
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: "Puoi muovere una pedina su due assi: in alto o in basso, a destra
          o sinistra.\n\nSe la pedina selezionata tocca una parete del campo o un\u2019altra
          pedina, il movimento sull\u2019asse corrispondente sar\xE0 bloccato."
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: "Se la pedina passa sopra un buco, ci cadr\xE0 dentro e non potrai
          pi\xF9 muoverla.\n\nUsa le pedine rosse per riempire i buchi."
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: "Se sbagli mossa, puoi tornare indietro di un solo passo con il pulsante
          \u201CBack\u201D. \n\nSe la situazione \xE8 pi\xF9 complicata, premi il
          pulsante \u201CReset\u201D e ricomincia da capo."
      - Sequenzale_Globale: 1
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: "<color=#888787><size=85%><b>Scopo</b></size></color>\n<size=90%>Portare
          ogni pedina numerata sulla casella corretta; usare le rosse per coprire
          i buchi.</size>\n\n<color=#888787><size=85%><b>Mosse</b></size></color>\n<size=90%>\u2022
          Selezionare una pedina con il joystick\n- Spostarla sulla casella corretta\n-
          Usare le pedine rosse per coprire i buchi</size>\n\n<color=#888787><size=85%><b>Attenzione</b></size></color>\n<size=90%>\u2022
          Le pedine non si muovono se bloccate da pareti o altre pedine\n- Se incastrato
          puoi tornare indietro di una mossa o resettare la partita</size>"
      StepForCompletition:
      - Prima mossa (sokoban)
      - Gioca a sokoban
      PersonalizedPrefab: {fileID: 0}
  - ChapterName: Scalak
    feedbacks:
    - FeedbackName: Istruzione Scalak
      pages:
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 1
        image: {fileID: 0}
        video: {fileID: 0}
        text: "L\u2019obiettivo del gioco \xE8 quello di riordinare le tessere  verdi.\n"
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: "L\u2019ordine corretto \xE8 quello che riproduce la sequenza di forme
          sulla destra.\n"
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: 'Puoi spostare una tessera solo in certi punti del campo, in base alla
          sua posizione e a quella delle altre tessere.


          Seleziona una
          tessera con il raycast o toccandola con il controller.'
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: "I volumi che compaiono indicano le posizione che la tessera pu\xF2
          occupare. Selezionali per spostare la tessera.\n"
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: "Una volta riordinate le tessere, posiziona le forme sulla destra all\u2019interno
          dei fori corrispondenti."
      - Sequenzale_Globale: 1
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: "<color=#888787><size=85%><b>Scopo</b></size></color>\n<size=90%>Riordinare
          le tessere secondo il pattern mostrato, poi posizionare le forme sui fori.</size>\n\n<color=#888787><size=85%><b>Mosse</b></size></color>\n<size=90%>\u2022
          Osservare l'ordine delle forme mostrato a destra\n- Selezionare una tessera
          e spostarla nelle caselle illuminate\n- Posizionare le forme sui fori corrispondenti</size>\n\n<color=#888787><size=85%><b>Attenzione</b></size></color>\n<size=90%>\u2022
          Le forme vanno posizionate sui fori solo dopo aver riordinato le tessere</size>"
      StepForCompletition:
      - Prima mossa (scalak)
      - Gioca a scalak
      PersonalizedPrefab: {fileID: 0}
  - ChapterName: Visivo-Verbale
    feedbacks:
    - FeedbackName: Ricorda la sequenza
      pages:
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 1
        image: {fileID: 0}
        video: {fileID: 0}
        text: "L'obbiettivo \xE8 quello di replicare la sequenza mostrata interagendo
          con gli oggetti. Prima di iniziare, puoi interagire con gli oggetti per
          provarli."
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: "Schiaccia il pulsante per far comparire una sequenza sullo schermo.\nLa
          sequenza pu\xF2 essere composta da immagini o parole"
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: Una volta memorizzata, prova a replicarla interagendo con gli oggetti
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: "Se ti accorgi di non ricordarti pi\xF9 la sequenza, puoi ritornare
          dallo schermo e ri-schiacciare il pulsante per visualizzare la sequenza"
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: "Se interagisci con un oggetto nel momento sbagliato, questo lampegger\xE0
          di rosso, mostrandoti l'errore."
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: "Una volta finito un round, premi nuovamente il pulsante per passare
          all'altra modalit\xE0, in modo da completare sia la sequenza fatta da parole
          che da immagini."
      - Sequenzale_Globale: 1
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: "<color=#888787><size=85%><b>Scopo</b></size></color>\n<size=90%>Memorizzare
          la sequenza mostrata e replicarla interagendo con gli oggetti.</size>\n\n<color=#888787><size=85%><b>Mosse</b></size></color>\n<size=90%>\u2022
          Premere il pulsante per vedere la sequenza sullo schermo\n- Interagire
          con gli oggetti nell'ordine memorizzato</size>\n- Ripremere il pulsante
          una votlta finito un round per passare alla prossima modalit\xE0</size>\n\n<color=#888787><size=85%><b>Attenzione</b></size></color>\n<size=90%>\u2022
          Puoi tornare allo schermo in qualsiasi momento per rivedere la sequenza\n-
          Entrambe le modalit\xE0 devono essere completate per concludere il gioco</size>"
      StepForCompletition:
      - inizia a giocare a ricordaInteractable
      - Ricorda gli interactable
      PersonalizedPrefab: {fileID: 0}
    - FeedbackName: Memory
      pages:
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 1
        image: {fileID: 0}
        video: {fileID: 0}
        text: "L'obbiettivo del gioco \xE8 girare le coppie di carte uguali, dopo
          averle memorizzate"
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: Una volta premuto il pulsante, le carte verrano scoperte per alcuni
          secondi. Cerca di memorizzare le coppie prima che queste tornino ad essere
          coperte
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: Seleziona le carte con il controller, se selezioni due carte uguali,
          queste rimarrano scoperte fino alla fine del gioco.
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: "Una volta finito il round, premi di nuovo il pulsante per passare
          all'altra modalit\xE0"
      - Sequenzale_Globale: 1
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: "<color=#888787><size=85%><b>Scopo</b></size></color>\n<size=90%>Abbinare
          tutte le coppie di carte uguali scoprendole a memoria.</size>\n\n<color=#888787><size=85%><b>Mosse</b></size></color>\n<size=90%>\u2022
          Premere il pulsante per scoprire tutte le carte\n- Memorizzare la posizione
          delle coppie\n- Selezionare le carte uguali una volta coperte</size>\n\n<color=#888787><size=85%><b>Attenzione</b></size></color>\n<size=90%>\u2022
          Le carte possono essere parole o immagini</size>"
      StepForCompletition:
      - inizia a giocare a memory
      - Memory
      PersonalizedPrefab: {fileID: 0}
    - FeedbackName: Ricorda le parole e le immagini
      pages:
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 1
        image: {fileID: 0}
        video: {fileID: 0}
        text: "L'obbiettivo del gioco \xE8 ricordare l'ordine con cui sono comparse
          le parole o le immagini"
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: Premi il bottone per mostrare la sequenza di elementi e cerca di memorizzare
          l'ordine di comparsa
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: "Terminata la sequenza, seleziona gli elementi con il controller nell'ordine
          in cui sono comparsi. Premi nuovamente il bottone per passare all'altra
          modalit\xE0"
      - Sequenzale_Globale: 1
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: "<color=#888787><size=85%><b>Scopo</b></size></color>\n<size=90%>Ricordare
          l'ordine in cui gli elementi compaiono e selezionarli nella stessa sequenza.</size>\n\n<color=#888787><size=85%><b>Mosse</b></size></color>\n<size=90%>\u2022
          Premere il bottone per mostrare la sequenza\n- Selezionare gli elementi
          nell'ordine in cui sono comparsi</size>\n\n<color=#888787><size=85%><b>Attenzione</b></size></color>\n<size=90%>\u2022
          L'ordine di comparsa \xE8 l'unico criterio, non la posizione degli elementi</size>"
      StepForCompletition:
      - inizia a giocare a ricordaInParoleImmagini
      - Test parole
      PersonalizedPrefab: {fileID: 0}
  - ChapterName: Sintetizzatore Chimerico
    feedbacks:
    - FeedbackName: Sintetizzatore Chimerico
      pages:
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 1
        image: {fileID: 0}
        video: {fileID: 0}
        text: "Pare che questa macchina possa fondere assieme creature appertenti
          al mondo animale. E\u2019 molto utile se per esempio... Vabb\xE8 tu costruiscila
          e basta. Non fare domande. "
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: 'iIn questa stanza troverai i componenti necessari e le istruzioni
          per montarli assieme. '
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: "Ma attenzione, non potrai tenerle sempre sottomano, dovrai memorizzarle.\n
          \nMeno tempo ci metterai a montare la macchina e pi\xF9 punti otterrai.
          \n\nSe metterai i componenti nel posto sbagliato, otterrai una penalit\xE0."
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 0
        image: {fileID: 0}
        video: {fileID: 0}
        text: "Premi il pulsante per vedere le istruzioni, memorizza la posizione
          dei componenti e monta il Sintetizzatore Chimerico. \n\nSe ti dimentichi
          qualcosa, puoi tornare dallo schermo e ri-premere il pulsante."
      - Sequenzale_Globale: 0
        Visivo_Verbale: 1
        isIntroductory: 0
