%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 19dd4061a1f2d754ea6a2c095c572429, type: 3}
  m_Name: FeedbackRepository
  m_EditorClassIdentifier: 
  SingleContainer_Attivo: {fileID: 781630661673262138, guid: 7de8152ce2a2f3749aba1fc3a44d2d68, type: 3}
  SingleContainer_Riflessivo: {fileID: 781630661673262138, guid: 0af613de78e3851479d373ae47fafa88, type: 3}
  MultipleContainer: {fileID: 781630661673262138, guid: 54ee856b97887bd4ca92758fc607acc9, type: 3}
  globalPath:
    verbalPath:
      attivo:
      - ChapterName: Segnalazione incendio
        feedbacks:
        - FeedbackName: '<color=#00DFA2>Capitolo 1</color>: Segnalazione Incendio'
          pages:
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "<color=#00DFA2><b>Obbiettivo</b></color>\r\nSegnalare l'incendio
              per avvisare il personale scolastico, gli occupanti dell'edificio e
              i soccorritori.\n\r\n<color=#00DFA2><b>Procedura</b></color>\r\n<color=#888888>\u2022</color>
              Avvisa il personale scolastico utilizzando il telefono\r\n<color=#888888>\u2022</color>
              Attiva l'allarme antincendio in corridoio  \r\n<color=#888888>\u2022</color>
              Avvisa i vigili del fuoco utiizzando il telefono al numero 115 e fornisci
              loro informazioni"
          StepForCompletition:
          - Eseguire chiamata1
          - completa Domande
          PersonalizedPrefab: {fileID: 0}
          needsButtonToBeCompleted: 0
          applyReflectiveEffects: 1
      - ChapterName: "Interruzione elettricit\xE0+gas"
        feedbacks:
        - FeedbackName: "<color=#00DFA2>Capitolo 2</color>: Disattiva elettricit\xE0
            e gas"
          pages:
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "<color=#00DFA2><b>Obbiettivo</b></color>\r\nPrima di lasciare
              l'area, interrompi le fonti di rischio per evitare che l'incendio si
              aggravi.\n\r\n<color=#00DFA2><b>Procedura</b></color>\r\n<color=#888888>\u2022</color>
              Solleva gli interruttori elettrici giusti per eliminare il rischio
              di cortocircuiti.  \r\n<color=#888888>\u2022</color> Gira la manopola
              del gas per evitare il rischio di esplosioni."
          StepForCompletition:
          - "Disattiva elettricit\xE0 e gas"
          - Play audio Gas
          PersonalizedPrefab: {fileID: 0}
          needsButtonToBeCompleted: 0
          applyReflectiveEffects: 1
      - ChapterName: Isola Incendio
        feedbacks:
        - FeedbackName: '<color=#00DFA2>Capitolo 3</color>: Isolamento incendio'
          pages:
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "<color=#00DFA2><b>Obbiettivo</b></color>\r\nValutare rapidamente
              l'incendio e, se necessario, isolare la stanza per limitare fiamme
              e fumo.\n\r\n<color=#00DFA2><b>Procedura</b></color>\r\n<color=#888888>\u2022</color>
              Valuta l'incendio: se \xE8 troppo esteso, esci subito senza tentare
              di spegnerlo.  \r\n<color=#888888>\u2022</color> Chiudi la porta per
              rallentare fuoco e fumo.  \r\n<color=#888888>\u2022</color> Tappa le
              fessure con tessuti disponibili, come felpe, per bloccare il fumo."
          StepForCompletition:
          - Istruzioni isola Incendio
          - "Non \xE8 bastato... usa la giacca per bloccare il fumo"
          PersonalizedPrefab: {fileID: 0}
          needsButtonToBeCompleted: 0
          applyReflectiveEffects: 1
      - ChapterName: Giro di perlustrazione
        feedbacks:
        - FeedbackName: '<color=#00DFA2>Capitolo 4</color>: Giro di Perlustrazione'
          pages:
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "<color=#00DFA2><b>Obbiettivo</b></color>\r\nVerificare che nessuno
              sia rimasto nelle aule e assistere chi non ha ancora evacuato.\n\t\r\n<color=#00DFA2><b>Procedura</b></color>\r\n<color=#888888>\u2022</color>
              Fai il giro delle aule e controlla che non ci sia nessuno rimasto indietro. 
              \r\n<color=#888888>\u2022</color> Se trovi qualcuno, accompagnalo subito
              verso l'uscita pi\xF9 vicina.  \r\n<color=#888888>\u2022</color> Chiudi
              sempre la porta dell'aula una volta perlustrata.\n<color=#888888>\u2022</color>
              Completa tutti gli step per un'aula prima di passare alla successiva."
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "Se hai dubbi sulle uscite, consulta la <b><color=#00DFA2>mappa
              di evacuazione</color></b>: i <b><color=#00DFA2>numeri verdi</color></b>
              indicano l\u2019ordine di vicinanza delle uscite. Se l\u2019uscita
              pi\xF9 vicina \xE8 bloccata, utilizza la successiva disponibile.\r\n\r\nLe
              persone con <b><color=#00DFA2>disabilit\xE0</color></b> potrebbero
              aver bisogno di supporto aggiuntivo, come la <b><color=#00DFA2>spinta
              della sedia a rotelle</color></b> per raggiungere l\u2019uscita in
              sicurezza."
          StepForCompletition:
          - Istruzioni Giro Di Perlustrazioni
          - Perlustra tutta la scuola e chiudi le porte
          PersonalizedPrefab: {fileID: 0}
          needsButtonToBeCompleted: 1
          applyReflectiveEffects: 1
      - ChapterName: Segnalazione assenti
        feedbacks:
        - FeedbackName: '<color=#00DFA2>Capitolo 5</color>: Segnalazione assenti'
          pages:
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "<color=#00DFA2><b>Obbiettivo</b></color>\r\nVerificare che tutti
              gli studenti siano presenti e segnalare eventuali dispersi.\n\r\n<color=#00DFA2><b>Procedura</b></color>\r\n<color=#888888>\u2022</color>
              Parla subito con gli insegnanti una volta evacuati.\r\n<color=#888888>\u2022</color>
              Verifica il numero di studenti presenti.\r\n<color=#888888>\u2022</color>
              Segnala eventuali dispersi, tenendo conto degli assenti."
          StepForCompletition:
          - segnala assenti
          PersonalizedPrefab: {fileID: 0}
          needsButtonToBeCompleted: 0
          applyReflectiveEffects: 1
      - ChapterName: Estintore generico Optional
        feedbacks:
        - FeedbackName: '<color=#FFD700>Imprevisto</color>: Fuoco su solido'
          pages:
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "<color=#FFD700><b>Obbiettivo</b></color>\r\nSpegnere in sicurezza
              un incendio gestibile per liberare il percorso e proseguire con l'evacuazione.\n\r\n<color=#FFD700><b>Procedura</b></color>\n<color=#888888>\u2022</color>
              In caso di fumo, procedi stando accovacciato per evitare di respirarlo.\r\n<color=#888888>\u2022</color>
              Valuta i materiali coinvolti e scegli l'estintore pi\xF9 adatto.  \r\n<color=#888888>\u2022</color>
              Rimuovi la chiave di sicurezza.  \r\n<color=#888888>\u2022</color>
              Punta l'ugello alla base delle fiamme.  \r\n<color=#888888>\u2022</color>
              Premi il trigger e mantieni il flusso fino allo spegnimento completo
              del fuoco."
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: 'Se stanno bruciando <b><color=#FFD700>materiali solidi</color></b>
              (come carta, legno o arredi), usa un estintore ad <b><color=#FFD700>acqua</color></b>
              o a <b><color=#FFD700>schiuma</color></b>.


              Se invece
              si tratta di <b><color=#FFD700>materiali elettrici</color></b>, utilizza
              un estintore a <b><color=#FFD700>CO2</color></b>.'
          StepForCompletition:
          - (solido) Grab extiguisher
          - Extinguish fire
          PersonalizedPrefab: {fileID: 0}
          needsButtonToBeCompleted: 0
          applyReflectiveEffects: 1
      - ChapterName: Primo soccorso Optional
        feedbacks:
        - FeedbackName: '<color=#FFD700>Imprevisto</color>: Primo soccorso'
          pages:
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "<color=#FFD700><b>Obbiettivo</b></color>\r\nPrestare il primo
              soccorso a una lieve scottatura.\n\r\n<color=#FFD700><b>Procedura</b></color>\r\n<color=#888888>\u2022</color>
              Raffredda la zona scottata con acqua fresca per ridurre la temperatura
              della pelle.  \r\n<color=#888888>\u2022</color> Asciuga delicatamente
              la zona interessata\r\n<color=#888888>\u2022</color> Proteggi la zona
              con una garza sterile."
          StepForCompletition:
          - Grab bottle
          - play audio
          PersonalizedPrefab: {fileID: 0}
          needsButtonToBeCompleted: 0
          applyReflectiveEffects: 1
      - ChapterName: Vie di fuga Optional
        feedbacks:
        - FeedbackName: '<color=#FFD700>Imprevisto</color>: Via di fuga bloccata'
          pages:
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "<color=#FFD700><b>Obbiettivo</b></color>\r\nAiutare le persone
              a raggiungere un'uscita sicura quando il percorso scelto \xE8 bloccato.\n\r\n<color=#FFD700><b>Procedura</b></color>\r\n<color=#888888>\u2022</color>
              Indica l'uscita pi\xF9 vicina alla persona utilizzando la mappa sul
              pannello della mano.  \r\n<color=#888888>\u2022</color> Chiudi la mappa
              e prosegui con l'evacuazione."
          StepForCompletition:
          - Seleziona una via di fuga alternativa
          - Chiudi la mappa
          PersonalizedPrefab: {fileID: 0}
          needsButtonToBeCompleted: 0
          applyReflectiveEffects: 1
      - ChapterName: Fuoco su liquido Optional
        feedbacks:
        - FeedbackName: '<color=#FFD700>Imprevisto</color>: Fuoco su liquido infiammabile'
          pages:
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "<color=#FFD700><b>Obbiettivo</b></color>\r\nSpegnere in sicurezza
              un incendio causato da un liquido infiammabile senza propagare le fiamme.\n\r\n<color=#FFD700><b>Procedura</b></color>\r\n<color=#888888>\u2022</color>
              Utilizza un estintore a CO2 oppure a schiuma.  \r\n<color=#888888>\u2022</color>
              Rimuovi la chiave di sicurezza e afferra l'ugello.\r\n<color=#888888>\u2022</color>Premi
              la leva per attivare il getto e mantienilo il pi\xF9 possibile parallelo
              al pavimento per evitare schizzi e propagazione dell'incendio."
          StepForCompletition:
          - Trova L'estintore a CO2
          - Estingui il fuoco (CO2)
          PersonalizedPrefab: {fileID: 0}
          needsButtonToBeCompleted: 0
          applyReflectiveEffects: 1
      riflessivo:
      - ChapterName: Segnalazione incendio
        feedbacks:
        - FeedbackName: '<color=#00DFA2>Capitolo 1</color>: Segnalazione Incendio'
          pages:
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "<color=#00DFA2><b>Obbiettivo</b></color>\n\nIn questo capitolo
              hai il compito di <b><color=#00DFA2>segnalare l\u2019incendio</color></b>
              per avvisare il personale scolastico, gli occupanti dell\u2019edificio
              e i soccorritori. Il personale scolastico pu\xF2 avviare l\u2019evacuazione
              in modo ordinato, mentre l\u2019allarme consente di avvisare rapidamente
              tutti gli occupanti. Infine, puoi contattare i Vigili del Fuoco fornendo
              informazioni utili sull\u2019emergenza."
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "<color=#00DFA2><b>Procedura</b></color>\n\n<color=#888888>\u2022</color>
              Per avvisare il personale scolastico, usa il <b><color=#00DFA2>telefono</color></b>,
              premi il tasto <b><color=#00DFA2>\"personale scolastico\"</color></b>
              e alza la cornetta.  \n\n<color=#888888>\u2022</color> Per attivare
              l\u2019allarme antincendio, vai al <b><color=#00DFA2>pulsante di allarme</color></b>
              nel corridoio, solleva la <b><color=#00DFA2>copertura di sicurezza</color></b>
              e premi il pulsante.  \n\n<color=#888888>\u2022</color> Per avvisare
              i Vigili del Fuoco, utilizza nuovamente il <b><color=#00DFA2>telefono</color></b>,
              premi <b><color=#00DFA2>115</color></b> e alza la cornetta. Rispondi
              alle domande tramite il <b><color=#00DFA2>pannello sulla mano</color></b>
              usando le informazioni presenti nel tuo ufficio."
          StepForCompletition:
          - Eseguire chiamata1
          - completa Domande
          PersonalizedPrefab: {fileID: 0}
          needsButtonToBeCompleted: 0
          applyReflectiveEffects: 1
      - ChapterName: "Interruzione elettricit\xE0+gas"
        feedbacks:
        - FeedbackName: "<color=#00DFA2>Capitolo 2</color>: Disattiva elettricit\xE0
            e gas"
          pages:
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "<color=#00DFA2><b>Obbiettivo</b></color>\n\nIn questo capitolo
              devi <b><color=#00DFA2>interrompere le fonti di rischio</color></b>
              per evitare che l\u2019incendio si aggravi. Disattivare l\u2019<b><color=#00DFA2>elettricit\xE0</color></b>
              riduce il rischio di cortocircuiti che possono propagare il fuoco,
              mentre interrompere il <b><color=#00DFA2>gas</color></b> evita fughe
              pericolose ed eventuali esplosioni."
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "<color=#00DFA2><b>Procedura</b></color>\n\n<color=#888888>\u2022</color>
              Per interrompere l\u2019<b><color=#00DFA2>elettricit\xE0</color></b>,
              solleva o premi gli <b><color=#00DFA2>interruttori elettrici</color></b>
              corretti secondo le informazioni presenti nel tuo ufficio.  \n\n<color=#888888>\u2022</color>
              Per disattivare il <b><color=#00DFA2>gas</color></b>, ruota la <b><color=#00DFA2>valvola</color></b>
              corretta in senso antiorario secondo le informazioni presenti nel tuo
              ufficio."
          StepForCompletition:
          - "Disattiva elettricit\xE0 e gas"
          - Play audio Gas
          PersonalizedPrefab: {fileID: 0}
          needsButtonToBeCompleted: 0
          applyReflectiveEffects: 1
      - ChapterName: Isola Incendio
        feedbacks:
        - FeedbackName: '<color=#00DFA2>Capitolo 3</color>: Isolamento incendio'
          pages:
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "<color=#00DFA2><b>Obbiettivo</b></color>\n\nIn questo capitolo
              devi <b><color=#00DFA2>valutare rapidamente l\u2019incendio</color></b>,
              riconoscendo quando il fuoco \xE8 troppo grande per essere spento in
              sicurezza. In questi casi, tentare lo spegnimento aumenta l\u2019esposizione
              a rischi eccessivi: \xE8 preferibile <b><color=#00DFA2>uscire dalla
              stanza</color></b> e <b><color=#00DFA2>chiudere la porta</color></b>,
              cos\xEC da limitare la diffusione di fiamme e fumo.\n"
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "<color=#00DFA2><b>Procedura</b></color>\n\n<color=#888888>\u2022</color>
              Entra nella stanza per valutare l\u2019incendio. Quando un incendio
              \xE8 troppo esteso, <b><color=#00DFA2>esci subito</color></b> dalla
              stanza senza tentare di spegnerlo.  \n\n<color=#888888>\u2022</color>
              <b><color=#00DFA2>Chiudi la porta</color></b> per rallentare la propagazione
              di fuoco e fumo.  \n\n<color=#888888>\u2022</color> Tappa le fessure
              inferiori della porta con <b><color=#00DFA2>tessuti disponibili </color></b>
              (ad esempio indumenti o una felpa), posizionandoli lungo il bordo per
              ridurre il passaggio del fumo, che renderebbe l'aria poco respirabile."
          StepForCompletition:
          - Istruzioni isola Incendio
          - "Non \xE8 bastato... usa la giacca per bloccare il fumo"
          PersonalizedPrefab: {fileID: 0}
          needsButtonToBeCompleted: 0
          applyReflectiveEffects: 1
      - ChapterName: Giro di perlustrazione
        feedbacks:
        - FeedbackName: '<color=#00DFA2>Capitolo 4</color>: Giro di Perlustrazione'
          pages:
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "<color=#00DFA2><b>Obbiettivo</b></color>\n\nIn questo capitolo
              devi <b><color=#00DFA2>verificare che nessuno sia rimasto nelle aule</color></b>
              e assistere chi non ha ancora evacuato accompagnandolo all'uscita pi\xF9
              vicina.\n\n\xC8 importante anche <b><color=#00DFA2>chiudere le porte
              delle aule</color></b> per limitare la propagazione di fuoco e fumo."
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "<color=#00DFA2><b>Procedura</b></color>\n\n<color=#888888>\u2022</color>
              Fai il giro delle <b><color=#00DFA2>aule principali</color></b> e controlla
              che non ci sia nessuno rimasto indietro. \n\n<color=#888888>\u2022</color>
              Se trovi qualcuno, <b><color=#00DFA2>accompagnalo all\u2019uscita pi\xF9
              vicina</color></b>, avvicinandoti a lui in modo che possa seguirti. 
              \n\n<color=#888888>\u2022</color> Chiudi sempre la <b><color=#00DFA2>porta
              dell\u2019aula</color></b> una volta perlustrata.  \n\n<color=#888888>\u2022</color>
              Completa tutte le operazioni dell\u2019aula prima di passare alla successiva."
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "Se hai dubbi, consulta la <color=#00DFA2>mappa di evacuazione</color></b>
              vicino alla porta. I numeri verdi sulla mappa mostrano l'ordine di
              vicinanza delle uscite: se l'uscita pi\xF9 vicina \xE8 bloccata, utilizza
              la seconda pi\xF9 vicina."
          StepForCompletition:
          - Istruzioni Giro Di Perlustrazioni
          - Perlustra tutta la scuola e chiudi le porte
          PersonalizedPrefab: {fileID: 0}
          needsButtonToBeCompleted: 1
          applyReflectiveEffects: 1
      - ChapterName: Segnalazione assenti
        feedbacks:
        - FeedbackName: '<color=#00DFA2>Capitolo 5</color>: Segnalazione assenti'
          pages:
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "<color=#00DFA2><b>Obbiettivo</b></color>\n\nIn questo capitolo
              devi <b><color=#00DFA2>parlare con gli insegnanti</color></b> e ricevere
              informazioni sulle classi, cos\xEC da poter <b><color=#00DFA2>segnalare
              eventuali dispersi</color></b> ai soccorritori.\r\n\r\n"
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "<color=#00DFA2><b>Procedura</b></color>\n\n<color=#888888>\u2022</color>
              Avvicinati agli <b><color=#00DFA2>insegnanti</color></b> uno ad uno
              per raccogliere le informazioni e consulta i <b><color=#00DFA2>pannelli
              informativi</color></b>.  \n\n<color=#888888>\u2022</color> Segnala
              eventuali <b><color=#00DFA2>dispersi</color></b> utilizzando i pulsanti
              scorrevoli sui pannelli, tenendo conto di presenti e assenti."
          StepForCompletition:
          - segnala assenti
          PersonalizedPrefab: {fileID: 0}
          needsButtonToBeCompleted: 0
          applyReflectiveEffects: 1
      - ChapterName: Estintore generico Optional
        feedbacks:
        - FeedbackName: '<color=#FFD700>Imprevisto</color>: Fuoco su solido'
          pages:
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "<color=#FFD700><b>Obbiettivo</b></color>\n\nIn questo capitolo
              devi <b><color=#FFD700>spegnere in sicurezza un incendio di dimensioni
              ridotte</color></b> utilizzando l'estintore giusto in base al materiale
              coinvolto. Questo permetter\xE0 di liberare il percorso e proseguire
              con l\u2019evacuazione.\n\n<color=#FFD700><b>Attenzione</b></color>:
              In alcuni casi potresti vedere del fumo nella stanza. Se capitasse,
              prosegui accovacciato con la procedura.Il fumo tende a salire e accumularsi
              in alto; restare bassi riduce l\u2019inalazione di sostanze tossichee
              migliora la visibilit\xE0.\n\n"
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "<color=#FFD700><b>Procedura</b></color>\n\n<color=#888888>\u2022</color>
              Per prima cosa valuta i <b><color=#FFD700>materiali coinvolti</color></b>
              e prendi l\u2019<b><color=#FFD700>estintore pi\xF9 adatto</color></b>.\n\n<color=#888888>\u2022</color>
              Una volta preso, <b><color=#FFD700>rimuovi la chiave di sicurezza</color></b>:
              senza la rimozione l\u2019estintore non si attiva.  \n\n<color=#888888>\u2022</color>
              Afferra l\u2019<b><color=#FFD700>ugello</color></b> e puntalo alla
              <b><color=#FFD700>base delle fiamme</color></b>, cio\xE8 il punto di
              origine del fuoco da cui \xE8 pi\xF9 efficace estinguerlo.  \n\n<color=#888888>\u2022</color>
              Premi la <b><color=#FFD700>leva di attivazione</color></b> e mantieni
              il flusso continuo fino allo spegnimento completo del fuoco.\n\nNella
              pagina seguente troverai indicazioni sugli estintori adeguati ai materiali
              coinvolti."
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "Se stanno bruciando <b><color=#FFD700>materiali solidi</color></b>
              (come carta, legno o arredi), usa un estintore ad <b><color=#FFD700>acqua</color></b>
              o a <b><color=#FFD700>schiuma</color></b>.  \n\r\nQuesti agenti sono
              efficaci perch\xE9 agiscono <b><color=#FFD700>raffreddando il materiale
              e soffocando le fiamme</color></b>, riducendo la temperatura sotto
              il punto di combustione.\r\n\r\nSe invece si tratta di <b><color=#FFD700>materiali
              elettrici</color></b>, utilizza un estintore a <b><color=#FFD700>CO2</color></b>.\n 
              \r\nLa CO2 \xE8 preferita perch\xE9 <b><color=#FFD700>non conduce elettricit\xE0
              e non lascia residui</color></b>, evitando danni ai circuiti e riducendo
              il rischio di cortocircuiti."
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: '


'
          StepForCompletition:
          - (solido) Grab extiguisher
          - Extinguish fire
          PersonalizedPrefab: {fileID: 0}
          needsButtonToBeCompleted: 0
          applyReflectiveEffects: 1
      - ChapterName: Primo soccorso Optional
        feedbacks:
        - FeedbackName: '<color=#FFD700>Imprevisto</color>: Primo soccorso'
          pages:
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "<color=#FFD700><b>Obbiettivo</b></color>\n\nIn questo capitolo
              devi prestare soccorso a uno studente che ha subito una lieve scottatura
              durante l\u2019evacuazione. Nelle scottature lievi \xE8 necessario
              <b><color=#FFD700>raffreddare  la zona</color></b> per limitare il
              danno ai tessuti, mantenere l\u2019area <b><color=#FFD700>pulita</color></b>
              e <b><color=#FFD700>protetta</color></b> per ridurre il rischio di
              irritazioni o infezioni.\n"
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "<color=#FFD700><b>Procedura</b></color>\n\n<color=#888888>\u2022</color>
              Per prima cosa apri il <b><color=#FFD700>medkit</color></b>, dove troverai
              tutti gli strumenti necessari al primo intervento.  \n\n<color=#888888>\u2022</color>
              Prendi la <b><color=#FFD700>bottiglia di acqua pulita</color></b>,
              rimuovi il tappo e versa il contenuto sulla zona interessata per <b><color=#FFD700>raffreddare
              la scottatura</color></b>.  \n\n<color=#888888>\u2022</color> Asciuga
              delicatamente la zona con il <b><color=#FFD700>panno sterile</color></b>
              in modo da poter applicare la garza.\n\n<color=#888888>\u2022</color>
              Proteggi infine la zona con una <b><color=#FFD700>garza sterile</color></b>;
              se cade o si sporca, sostituiscila con una nuova per garantire la massima
              igiene."
          StepForCompletition:
          - Grab bottle
          - play audio
          PersonalizedPrefab: {fileID: 0}
          needsButtonToBeCompleted: 0
          applyReflectiveEffects: 1
      - ChapterName: Vie di fuga Optional
        feedbacks:
        - FeedbackName: '<color=#FFD700>Imprevisto</color>: Via di fuga bloccata'
          pages:
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "<color=#FFD700><b>Obbiettivo</b></color>\n\nIn questo capitolo
              devi aiutare una persona che si trova nei pressi di un\u2019uscita
              bloccata, indicando l\u2019uscita sicura pi\xF9 vicina disponibile.\n\r\n"
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "<color=#FFD700><b>Procedura</b></color>\n\n<color=#888888>\u2022</color>
              <b><color=#FFD700>Indica l\u2019uscita pi\xF9 vicina</color></b> alla
              persona utilizzando la <b><color=#FFD700>mappa sul pannello della mano</color></b>:
              seleziona l\u2019uscita corretta puntandola con il controller.\n\n<color=#888888>\u2022</color>
              <b><color=#FFD700>Chiudi la mappa</color></b> utilizzando il pulsante
              dedicato e prosegui con l\u2019evacuazione."
          StepForCompletition:
          - Seleziona una via di fuga alternativa
          - Chiudi la mappa
          PersonalizedPrefab: {fileID: 0}
          needsButtonToBeCompleted: 0
          applyReflectiveEffects: 1
      - ChapterName: Fuoco su liquido Optional
        feedbacks:
        - FeedbackName: '<color=#FFD700>Imprevisto</color>: Fuoco su liquido infiammabile'
          pages:
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "<color=#FFD700><b>Obbiettivo</b></color>\n\r\nIn questo capitolo
              dovrai spegnere in sicurezza un incendio causato da un <b><color=#FFD700>liquido
              infiammabile</b></color> senza propagare le fiamme. Incendi di questo
              tipo si comportano diversamente dagli altri ed \xE8 importante utilizzare
              l'estintore corretto e in modo adeguato per evitare che il combustibile
              si disperda."
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "<color=#FFD700><b>Procedura</b></color>\n\r\n<color=#888888>\u2022</color>
              Per prima cosa prendi un <b><color=#FFD700>estintore a CO2</color></b>
              oppure a <b><color=#FFD700>schiuma</color></b>.\n\r\n<color=#888888>\u2022</color>
              Rimuovi la <b><color=#FFD700>chiave di sicurezza</color></b> per sbloccare
              il dispositivo e renderlo operativo.  \n\r\n<color=#888888>\u2022</color>
              Afferra il cono e mantieni il getto il pi\xF9 possibile parallelo al
              pavimento, cos\xEC da ridurre il rischio di schizzi e limitare la propagazione
              dell\u2019incendio."
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "La CO2 o la schiuma sono indicati perch\xE9 <b><color=#FFD700>soffocano
              le fiamme riducendo l\u2019ossigeno disponibile</color></b> e non lasciano
              residui che potrebbero alimentare ulteriormente la combustione. "
          StepForCompletition:
          - Trova L'estintore a CO2
          - Estingui il fuoco (CO2)
          PersonalizedPrefab: {fileID: 0}
          needsButtonToBeCompleted: 0
          applyReflectiveEffects: 1
