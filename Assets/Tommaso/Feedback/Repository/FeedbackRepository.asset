%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 19dd4061a1f2d754ea6a2c095c572429, type: 3}
  m_Name: FeedbackRepository
  m_EditorClassIdentifier: 
  SingleContainer: {fileID: 781630661673262138, guid: 45c500a3433090b41bfe6ad005d270cf, type: 3}
  MultipleContainer: {fileID: 781630661673262138, guid: 4689bb12224f63240ac0e3056d230e01, type: 3}
  globalPath:
    verbalPath:
      attivo:
      - ChapterName: Segnalazione incendio
        feedbacks:
        - FeedbackName: '<color=#00DFA2>Capitolo 1</color>: Segnalazione Incendio'
          pages:
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "<color=#00DFA2><b>Obbiettivo</b></color>\r\nSegnalare immediatamente
              l'incendio per avvisare il personale scolastico, gli occupanti dell'edificio
              e i soccorritori.\n\r\n<color=#00DFA2><b>Procedura</b></color>\r\n<b>1.</b>
              Avvisa il personale scolastico  \r\n<b>2.</b> Attiva l'allarme antincendio 
              \r\n<b>3.</b> Chiama il 115\r\n"
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: 'Per avvertire il personale scolastico, <b><color=#00DFA2>utilizza
              il telefono</color></b>.



              Premi "personale scolastico"
              sul tastierino e alza la cornetta.'
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "Successivamente, <b><color=#00DFA2>attiva il pulsante di allarme
              antincendio pi\xF9 vicino</color></b> per avvisare tutte le persone
              presenti nell'edificio. lo puoi trovare in corridoio.\n\nSolleva la
              copertura di sicurezza e premi il pulsante."
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "Come ultima cosa, prendi il telefono e <b><color=#00DFA2>chiama
              subito i Vigili del Fuoco</color></b> al numero <b><color=#00DFA2>115</color></b>.\n\nPremi
              <b><color=#00DFA2>\"115\"</color></b> sul tastierino, alza la cornetta
              e rispondi alle domande dell\u2019operatore tramite il pannello sulla
              mano.\n"
          StepForCompletition:
          - Seleziona il tasto "Personale Scolastico"
          - completa Domande
          PersonalizedPrefab: {fileID: 0}
          needsButtonToBeCompleted: 0
          applyReflectiveEffects: 1
      - ChapterName: "Interruzione elettricit\xE0+gas"
        feedbacks:
        - FeedbackName: "<color=#00DFA2>Capitolo 2</color>: Disattiva elettricit\xE0
            e gas"
          pages:
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "<color=#00DFA2><b>Obbiettivo</b></color>\nPrima di lasciare l'area,
              interrompi le fonti di rischio per evitare che l'incendio si aggravi.\n\n<color=#00DFA2><b>Procedura</b></color>\n<b>1.</b>
              Solleva gli interruttori elettrici per eliminare il rischio di cortocircuiti. 
              \n<b>2.</b> Gira la manopola del gas per evitare il rischio di esplosioni."
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "Per disattivare l\u2019elettricit\xE0, utilizza gli <b><color=#00DFA2>interruttori
              giusti</color></b> secondo le informazioni presenti nel tuo ufficio."
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: 'Successivamente, <b><color=#00DFA2>interrompi il gas</color></b>
              ruotando la valvola giusta in senso antiorario. '
          StepForCompletition:
          - "Disattiva elettricit\xE0 e gas"
          - Play audio Gas
          PersonalizedPrefab: {fileID: 0}
          needsButtonToBeCompleted: 0
          applyReflectiveEffects: 1
      - ChapterName: Isola Incendio
        feedbacks:
        - FeedbackName: 'Capitolo 3: Isolamento incendio'
          pages:
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "<color=#00DFA2><b>Obbiettivo</b></color>\nValutare rapidamente
              l\u2019incendio e, se necessario, isolare la stanza per limitare fiamme
              e fumo.\n\n<color=#00DFA2><b>Procedura</b></color>\n<b>1.</b> Valuta
              l\u2019incendio: se \xE8 troppo esteso, esci subito senza tentare di
              spegnerlo.  \n<b>2.</b> Chiudi la porta per rallentare fuoco e fumo. 
              \n<b>3.</b> Tappa le fessure con tessuti disponibili per bloccare il
              fumo."
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "Per fuochi come quello che troverai in questa stanza, <b><color=#00DFA2>tentare
              di spegnerlo \xE8 troppo pericoloso</color></b>. Entra solo per una
              rapida valutazione ed esci immediatamente.\n"
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: <b><color=#00DFA2>Chiudi la porta</color></b> una volta uscito
              e isola il fumo utilizzando tessuti o indumenti. Utilizza i vestiti
              dietro di te. Prendine uno e posizionalo dove indicato.
          StepForCompletition:
          - Istruzioni isola Incendio
          - "Non \xE8 bastato... usa la giacca per bloccare il fumo"
          PersonalizedPrefab: {fileID: 0}
          needsButtonToBeCompleted: 0
          applyReflectiveEffects: 1
      - ChapterName: Giro di perlustrazione
        feedbacks:
        - FeedbackName: 'Capitolo 4: Giro di Perlustrazione'
          pages:
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "<color=#00DFA2><b>Obbiettivo</b></color>\r\nVerificare che nessuno
              sia rimasto nelle aule e assistere chi non ha ancora evacuato.\r\n\r\n<color=#00DFA2><b>Procedura</b></color>\r\n<b>1.</b>
              Fai il giro delle aule e controlla che non ci sia nessuno rimasto indietro. 
              \r\n<b>2.</b> Se trovi qualcuno, accompagnalo subito verso l\u2019uscita
              pi\xF9 vicina."
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "Se l\u2019aula \xE8 vuota, <b><color=#00DFA2>esci rapidamente</color></b>.\n\nSe
              una persona non ha ancora evacuato, <b><color=#00DFA2>accompagnala
              subito</color></b> verso l\u2019<b><color=#00DFA2>uscita pi\xF9 vicina</color></b>.
              Se hai dubbi, consulta la mappa di evacuazione: i numeri verdi indicano
              l\u2019ordine di vicinanza delle uscite, ma verifica che non siano
              bloccate.\n\nLe persone con disabilit\xE0 potrebbero aver bisogno di
              <b><color=#00DFA2>aiuto aggiuntivo</b>."
          StepForCompletition:
          - Istruzioni Giro Di Perlustrazioni
          - Perlustra tutta la scuola e chiudi le porte
          PersonalizedPrefab: {fileID: 0}
          needsButtonToBeCompleted: 1
          applyReflectiveEffects: 1
      - ChapterName: Segnalazione assenti
        feedbacks:
        - FeedbackName: 'Capitolo 5: Segnalazione assenti'
          pages:
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: Una volta evacuati, <color=#00DFA2>parla subito con gli insegnanti.
              Verifica il numero di studenti presenti e <color=#00DFA2>segnala eventuali
              dispersi, tenendo conto degli assenti.
          StepForCompletition:
          - segnala assenti
          PersonalizedPrefab: {fileID: 0}
          needsButtonToBeCompleted: 0
          applyReflectiveEffects: 1
      - ChapterName: Estintore generico Optional
        feedbacks:
        - FeedbackName: '<color=#FFD700>Imprevisto</color>: Fuoco su solido'
          pages:
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "<color=#00DFA2><b>Obbiettivo</b></color>\r\nSpegnere in sicurezza
              un incendio gestibile per liberare il percorso e proseguire con l'evacuazione.\r\n\r\n<color=#00DFA2><b>Procedura</b></color>\r\n<b>1.</b>
              Valuta i materiali coinvolti e scegli l\u2019estintore pi\xF9 adatto. 
              \r\n<b>2.</b> Rimuovi la chiave di sicurezza.  \r\n<b>3.</b> Punta
              l\u2019ugello alla base delle fiamme.  \r\n<b>4.</b> Premi il trigger
              e mantieni il flusso fino allo spegnimento completo del fuoco."
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: 'Se stanno bruciando <b><color=#00DFA2>materiali solidi</color></b>
              (come carta, legno o arredi), usa un estintore ad <b><color=#00DFA2>acqua</color></b>
              o a <b><color=#00DFA2>schiuma</color></b>.



              Se invece
              si tratta di <b><color=#00DFA2>materiali elettrici</color></b>, utilizza
              un estintore a <b><color=#00DFA2>CO2</color></b>.'
          StepForCompletition:
          - (solido) Grab extiguisher
          - Extinguish fire
          PersonalizedPrefab: {fileID: 0}
          needsButtonToBeCompleted: 0
          applyReflectiveEffects: 1
      - ChapterName: Primo soccorso Optional
        feedbacks:
        - FeedbackName: '<color=#FFD700>Imprevisto</color>: Primo soccorso'
          pages:
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "<color=#00DFA2><b>Obbiettivo</b></color>\r\nPrestare il primo
              soccorso alla persona ferita per trattare la lesione in sicurezza.\r\n\r\n<color=#00DFA2><b>Procedura</b></color>
              \n<b>1.</b> Disinfetta la ferita con acqua ossigenata. \n<b>2.</b>
              Asciuga delicatamente la zona con il panno. \n<b>3.</b> Applica la
              garza per proteggere la ferita.\r\n"
          StepForCompletition:
          - Grab bottle
          - play audio
          PersonalizedPrefab: {fileID: 0}
          needsButtonToBeCompleted: 0
          applyReflectiveEffects: 1
      - ChapterName: Vie di fuga Optional
        feedbacks:
        - FeedbackName: '<color=#FFD700>Imprevisto</color>: Via di fuga bloccata'
          pages:
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "<color=#00DFA2><b>Obbiettivo</b></color>\r\nAiutare le persone
              a raggiungere un'uscita sicura quando il percorso scelto \xE8 bloccato.\r\n\r\n<color=#00DFA2><b>Procedura</b></color>\r\n<b>1.</b>
              <b><color=#00DFA2>Indica l\u2019uscita pi\xF9 vicina</color></b> alla
              persona utilizzando la mappa sul pannello della mano.  \r\n<b>2.</b>
              <b><color=#00DFA2>Chiudi la mappa</color></b> e prosegui con l\u2019evacuazione."
          StepForCompletition:
          - Seleziona una via di fuga alternativa
          - Chiudi la mappa
          PersonalizedPrefab: {fileID: 0}
          needsButtonToBeCompleted: 0
          applyReflectiveEffects: 1
      - ChapterName: Fuoco su liquido Optional
        feedbacks:
        - FeedbackName: '<color=#FFD700>Imprevisto</color>: Fuoco su liquido infiammabile'
          pages:
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "<color=#00DFA2><b>Obbiettivo</b></color>\r\nSpegnere in sicurezza
              un incendio causato da un liquido infiammabile senza propagare le fiamme.\r\n\r\n<color=#00DFA2><b>Procedura</b></color>\r\n<b>1.</b>
              Identifica il materiale coinvolto come <b><color=#00DFA2>liquido infiammabile</color></b>. 
              \r\n<b>2.</b> Utilizza un <b><color=#00DFA2>estintore a CO\u2082</color></b>
              oppure a <b><color=#00DFA2>schiuma</color></b>.\r\n"
          - Sequenzale_Globale: 1
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "Prima di tutto, <b><color=#00DFA2>rimuovi la chiave di sicurezza</color></b>
              dall\u2019estintore. Solo dopo averla tolta potrai utilizzarlo.\r\n\r\nPrendi
              l\u2019<b><color=#00DFA2>ugello</color></b> e punta il tubo verso la
              base delle fiamme. In presenza di liquidi infiammabili, mantieni il
              getto il pi\xF9 possibile parallelo al pavimento per evitare schizzi
              che potrebbero propagare l\u2019incendio."
          StepForCompletition:
          - Grab bottle
          - play audio
          PersonalizedPrefab: {fileID: 0}
          needsButtonToBeCompleted: 0
          applyReflectiveEffects: 1
      riflessivo: []
    visualPath:
      attivo: []
      riflessivo: []
  sequentialPath:
    verbalPath:
      attivo:
      - ChapterName: Segnalazione incendio
        feedbacks:
        - FeedbackName: Chiama il personale scolastico
          pages:
          - Sequenzale_Globale: 0
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "In caso di incendio, <b><color=#00DFA2>avvisa subito il personale
              scolastico usando il telefono</color></b>. \n\nPremi \"personale scolastico\"
              sul tastierino e alza la cornetta.\r\n"
          StepForCompletition:
          - Seleziona il tasto "Personale Scolastico"
          - Eseguire chiamata
          PersonalizedPrefab: {fileID: 0}
          needsButtonToBeCompleted: 0
          applyReflectiveEffects: 1
        - FeedbackName: Attiva allarme
          pages:
          - Sequenzale_Globale: 0
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "Successivamente, <b><color=#00DFA2>attiva il pulsante di allarme
              antincendio pi\xF9 vicino</color></b> per avvisare tutte le persone
              presenti nell'edificio. \n\nSolleva la copertura di sicurezza e premi
              il pulsante.\r\n"
          StepForCompletition:
          - Attiva Allarme
          PersonalizedPrefab: {fileID: 0}
          needsButtonToBeCompleted: 0
          applyReflectiveEffects: 1
        - FeedbackName: Chiama i vigili del fuoco
          pages:
          - Sequenzale_Globale: 0
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "Prendi il telefono e <b><color=#00DFA2>chiama subito i Vigili
              del Fuoco</color></b> al numero <b><color=#00DFA2>115</color></b>.\r\n\r\nPremi
              <b><color=#00DFA2>\"115\"</color></b> sul tastierino, alza la cornetta
              e rispondi alle domande dell\u2019operatore tramite il pannello sulla
              mano.\r\n"
          StepForCompletition:
          - Seleziona il tasto "115"
          - completa Domande
          PersonalizedPrefab: {fileID: 0}
          needsButtonToBeCompleted: 0
          applyReflectiveEffects: 1
      - ChapterName: "Interruzione elettricit\xE0+gas"
        feedbacks:
        - FeedbackName: "Disattiva l'elettricit\xE0"
          pages:
          - Sequenzale_Globale: 0
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "Prima di lasciare l\u2019area, <b><color=#00DFA2>interrompi l\u2019elettricit\xE0
              dal quadro elettrico</color></b>utilizzando gli interruttori giusti.
              Questo riduce il rischio di cortocircuiti e ulteriori inneschi dell\u2019incendio.\r\n"
          StepForCompletition:
          - "Disattiva elettricit\xE0 e gas"
          PersonalizedPrefab: {fileID: 0}
          needsButtonToBeCompleted: 0
          applyReflectiveEffects: 1
        - FeedbackName: Disattiva il gas
          pages:
          - Sequenzale_Globale: 0
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: 'Inoltre, <b><color=#00DFA2>interrompi il gas</color></b> ruotando
              la valvola giusta in senso antiorario. Questo blocca il flusso ed evita
              possibili fughe pericolose.

'
          StepForCompletition:
          - Attiva feedback gas
          - Play audio Gas
          PersonalizedPrefab: {fileID: 0}
          needsButtonToBeCompleted: 0
          applyReflectiveEffects: 1
      - ChapterName: Isola Incendio
        feedbacks:
        - FeedbackName: Isola l'incendio
          pages:
          - Sequenzale_Globale: 0
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "Se l\u2019incendio \xE8 troppo grande, <b><color=#00DFA2>non tentare
              di spegnerlo</color></b>. \n\nEsci subito dalla stanza e <b><color=#00DFA2>chiudi
              la porta dietro di te</color></b>."
          StepForCompletition:
          - Raggiungi Incendio (nella stanza in fondo al corridoio a destra)
          - Non puoi domarli tutti... chiudi la porta e scappa
          PersonalizedPrefab: {fileID: 0}
          needsButtonToBeCompleted: 0
          applyReflectiveEffects: 1
        - FeedbackName: Usa stracci o indumenti per bloccare il fumo
          pages:
          - Sequenzale_Globale: 0
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: Se il fumo si diffonde, <b><color=#00DFA2>tappa le fessure della
              porta</color></b> con tessuti disponibili (stracci, asciugamani o indumenti),
              posizionandoli lungo i bordi inferiori e laterali per bloccare il fumo.
          StepForCompletition:
          - "Non \xE8 bastato... usa la giacca per bloccare il fumo"
          PersonalizedPrefab: {fileID: 0}
          needsButtonToBeCompleted: 0
          applyReflectiveEffects: 1
      - ChapterName: Giro di perlustrazione
        feedbacks:
        - FeedbackName: Perlustra la scuola
          pages:
          - Sequenzale_Globale: 0
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "Fai il <b><color=#00DFA2>giro delle aule</color></b> e verifica
              che non ci sia nessuno rimasto indietro. \n\nSe trovi qualcuno, <b><color=#00DFA2>accompagnalo
              subito verso l\u2019uscita pi\xF9 vicina</color></b>.\r\n"
          StepForCompletition:
          - Istruzioni Giro Di Perlustrazioni
          PersonalizedPrefab: {fileID: 0}
          needsButtonToBeCompleted: 1
          applyReflectiveEffects: 1
      - ChapterName: Aula 2(in fondo a sinistra)
        feedbacks:
        - FeedbackName: "Non c'\xE8 nessuno in Aula 2"
          pages:
          - Sequenzale_Globale: 0
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "Se l\u2019aula \xE8 vuota, <b><color=#00DFA2>esci rapidamente</color></b>.
              <b><color=#00DFA2>Una volta fuori, chiudi la porta</color></b> dell\u2019aula
              per impedire accessi e limitare l' eventuale propagazione del fuoco."
          StepForCompletition:
          - "No, non c'\xE8 nessuno in Aula 2"
          - Chiudi Porta Aula 2
          PersonalizedPrefab: {fileID: 0}
          needsButtonToBeCompleted: 0
          applyReflectiveEffects: 1
        - FeedbackName: Porta Jackie in salvo
          pages:
          - Sequenzale_Globale: 0
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "Se una persona non ha ancora evacuato, <b><color=#00DFA2>accompagnala
              subito</color></b> verso l\u2019<b><color=#00DFA2>uscita pi\xF9 vicina</color></b>.
              Se hai dubbi, consulta la mappa di evacuazione vicino alla porta."
          StepForCompletition:
          - "Si c'\xE8 Paolina in Aula2"
          - Chiudi Porta Aula 2
          PersonalizedPrefab: {fileID: 0}
          needsButtonToBeCompleted: 0
          applyReflectiveEffects: 1
      - ChapterName: Aula computer
        feedbacks:
        - FeedbackName: "Non c'\xE8 nessuno in Aula Computer"
          pages:
          - Sequenzale_Globale: 0
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "Se l\u2019aula \xE8 vuota, <b><color=#00DFA2>esci rapidamente</color></b>.
              <b><color=#00DFA2>Una volta fuori, chiudi la porta</color></b> dell\u2019aula
              per impedire accessi e limitare l' eventuale propagazione del fuoco."
          StepForCompletition:
          - "No, non c'\xE8 nessuno in Aula Computer"
          - Chiudi Porta Aula Computer
          PersonalizedPrefab: {fileID: 0}
          needsButtonToBeCompleted: 0
          applyReflectiveEffects: 1
        - FeedbackName: Porta Markus in salvo
          pages:
          - Sequenzale_Globale: 0
            Visivo_Verbale: 1
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "Se una persona non ha ancora evacuato, <b><color=#00DFA2>accompagnala
              subito</color></b> verso l\u2019<b><color=#00DFA2>uscita pi\xF9 vicina</color></b>.
              \n\nSe hai dubbi, consulta la mappa di evacuazione vicino alla porta."
          StepForCompletition:
          - "Si c'\xE8 Paolina"
          - Chiudi Porta Aula Computer
          PersonalizedPrefab: {fileID: 0}
          needsButtonToBeCompleted: 0
          applyReflectiveEffects: 1
      - ChapterName: Laboratorio di chimica
        feedbacks:
        - FeedbackName: "Non c'\xE8 nessuno in Laboratorio"
          pages:
          - Sequenzale_Globale: 0
            Visivo_Verbale: 1
            isIntroductory: 0
