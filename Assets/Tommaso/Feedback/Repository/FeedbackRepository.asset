      riflessivo:
      - ChapterName: Segnalazione incendio
        feedbacks:
        - FeedbackName: Chiama il personale scolastico
          pages:
          - Sequenzale_Globale: 0
            Visivo_Verbale: 0
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 32900000, guid: 9f4dc1b6c62b3e34eb234705dbd85469, type: 3}
            text: 'In caso di incendio, <b><color=#00DFA2>avvisa subito il personale
              scolastico usando il telefono</color></b>. '
          - Sequenzale_Globale: 0
            Visivo_Verbale: 0
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: La<b><color=#00DFA2>segnalazione </color></b> permette al personale
              scolastico di <b><color=#00DFA2>attivare le procedure di emergenza</color></b>
              e coordinare l'evacuazione in modo sicuro.
          StepForCompletition:
          - Eseguire chiamata1
          PersonalizedPrefab: {fileID: 0}
          needsButtonToBeCompleted: 0
          applyReflectiveEffects: 1
        - FeedbackName: Attiva allarme
          pages:
          - Sequenzale_Globale: 0
            Visivo_Verbale: 0
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 32900000, guid: 33d1e2148820662418083397e790c0f2, type: 3}
            text: "<b><color=#00DFA2>Attiva il pulsante di allarme antincendio pi\xF9
              vicino</color></b> per avvisare tutte le persone presenti nell'edificio.
              \r\n"
          - Sequenzale_Globale: 0
            Visivo_Verbale: 0
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: L'<b><color=#00DFA2>allarme antincendio</color></b> informa immediatamente
              gli occupanti del pericolo e permette di <b><color=#00DFA2>avviare
              l'evacuazione</color></b> senza ritardi, riducendo il rischio per le
              persone presenti.
          StepForCompletition:
          - Attiva Allarme
          PersonalizedPrefab: {fileID: 0}
          needsButtonToBeCompleted: 0
          applyReflectiveEffects: 1
        - FeedbackName: Chiama i vigili del fuoco
          pages:
          - Sequenzale_Globale: 0
            Visivo_Verbale: 0
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 32900000, guid: dae63f85d652ca848965e1088dc81b2f, type: 3}
            text: 'Prendi il telefono e <b><color=#00DFA2>chiama subito i Vigili
              del Fuoco</color></b> al numero <b><color=#00DFA2>115</color></b>.



'
          - Sequenzale_Globale: 0
            Visivo_Verbale: 0
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: 'In questo modo i <b><color=#00DFA2>Vigili del Fuoco</color></b>
              potranno <b><color=#00DFA2>valutare la situazione</color></b> e arrivare
              preparati  per gestire l''incendio.



'
          StepForCompletition:
          - Eseguire chiamata 2
          - completa Domande
          PersonalizedPrefab: {fileID: 0}
          needsButtonToBeCompleted: 0
          applyReflectiveEffects: 1
      - ChapterName: "Interruzione elettricit\xE0+gas"
        feedbacks:
        - FeedbackName: "Disattiva l'elettricit\xE0"
          pages:
          - Sequenzale_Globale: 0
            Visivo_Verbale: 0
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 32900000, guid: 54feed38cc9137345b514e723eb6ddcc, type: 3}
            text: "Prima di lasciare l\u2019area, <b><color=#00DFA2>interrompi l\u2019elettricit\xE0
              dal quadro elettrico</color></b>. Questo riduce il rischio di cortocircuiti
              e ulteriori inneschi dell\u2019incendio.\r\n"
          - Sequenzale_Globale: 0
            Visivo_Verbale: 0
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 0}
            text: "Disattivare l\u2019<b><color=#00DFA2>alimentazione elettrica</color></b>
              riduce il rischio di <b><color=#00DFA2>cortocircuiti</color></b> e
              di nuovi inneschi che potrebbero aggravare l\u2019incendio."
          StepForCompletition:
          - "Disattiva elettricit\xE0 e gas"
          - Attiva feedback gas
          PersonalizedPrefab: {fileID: 0}
          needsButtonToBeCompleted: 0
          applyReflectiveEffects: 1
