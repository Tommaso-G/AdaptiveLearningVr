          pages:
          - Sequenzale_Globale: 0
            Visivo_Verbale: 0
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 32900000, guid: 94678765f47f7db45a15b44f10fc9291, type: 3}
            text: 'Inoltre, <b><color=#00DFA2>interrompi il gas</color></b>. Questo
              blocca il flusso ed evita possibili fughe pericolose.

'
          - Sequenzale_Globale: 0
            Visivo_Verbale: 0
            isIntroductory: 0
            image: {fileID: 0}
            video: {fileID: 32900000, guid: 94678765f47f7db45a15b44f10fc9291, type: 3}
            text: 'Inoltre, <b><color=#00DFA2>interrompi il gas</color></b>. Questo
