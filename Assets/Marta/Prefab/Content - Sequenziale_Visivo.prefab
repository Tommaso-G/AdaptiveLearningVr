      m_Calls: []
  m_text: 'Segui i <color=#69CFB5FF>simboli di istruzione</color> per completare
    i passaggi della <color=#69CFB5FF>procedura base</color>.



    I <color=#D5C51CFF>simboli
    di imprevisto</color> indicano ostacoli aggiuntivi da risolvere prima di continuare.
    <color=#D5C51CFF>Non fanno parte della procedura base</color>.'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
