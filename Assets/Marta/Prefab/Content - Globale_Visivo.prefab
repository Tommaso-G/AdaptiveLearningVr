  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "</size>\r\n<color=#888787><size=85%><b>Procedura</b></size></color>\r\n<size=90%>\u2022
    In questa stanza sono presenti informazioni importanti. Controlla i <color=#69CFB5FF>documenti
    sulla scrivania e i cartelloni sulle pareti</color>. Alcuni step richiedono nozioni
    specifiche per essere completati. <color=#69CFB5FF>Controllali di nuovo ad ogni
    iterazione</color>.\r\n\r\n\u2022 Una volta fuori da questo ufficio, cerca i
    <color=#69CFB5FF>simboli d'istruzione</color> e avvicinati, indicano uno passaggio
    della <color=#69CFB5FF>procedura di base</color>.\r\n\r\n\r\n\r\n\u2022 Quello
    sotto \xE8 un <color=#D5C51CFF>simbolo d'imprevisto</color>, devi completarlo
    prima di proseguire, ma <color=#D5C51CFF>non fa parte della procedura base</color>.</size>"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
