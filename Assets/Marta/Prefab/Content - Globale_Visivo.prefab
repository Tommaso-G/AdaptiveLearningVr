  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "<color=#888787><size=85%><b>UI</b></size></color>\n\u2022 Alcune <color=#69CFB5FF>slide
    d'istruzione</color> presentano <color=#69CFB5FF>un tasto \"ho capito\"</color>.
    Devi premerlo per proseguire con la procedura, <color=#69CFB5FF>altrimenti non
    andrai avanti</color>.\n\r\n\u2022 Durante la procedura potrebbero comparire
    dei <color=#69CFB5FF>pannelli UI sul tuo controller sinistro</color>. Alcuni
    servono per completare lo step, altri forniscono informazioni su azioni da compiere
    o errori commessi. \r\n\r\n</size>"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
