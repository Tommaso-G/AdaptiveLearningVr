  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "<color=#888787><size=85%><b>Aiuti</b></size></color>\r\n<size=90%>\u2022
    Ogni volta che completi un passaggio correttamente, <color=#69CFB5FF>gli aiuti
    dello step diminuiranno</color>, fino a scomparire del tutto.\r\n \r\n\u2022
    Dalla <color=#69CFB5FF>seconda</color> iterazione in poi, <color=#69CFB5FF>se
    non vedi simboli d'istruzione</color> da nessuna parte, potrebbe voler dire che
    devi ricordare i passaggi da solo. \r\n\r\n\u2022 Cerca di ricordare lo step
    successivo della procedura, ma presta sempre attenzione all'ambiente attorno
    a te per non perderti <color=#69CFB5FF>eventuali imprevisti</color>."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
